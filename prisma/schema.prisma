// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------

enum Role {
  contestant
  admin
}

enum Status {
  pending
  shortlisted
  approved
  rejected
}

enum PhotoType {
  profile
  full_body
  gallery
}

enum MediaType {
  image
  video
}

enum MediaCategory {
  events
  backstage
  finalists
  promo
}

enum ActionType {
  approve
  reject
  publish
  delete
  update
}

enum TargetType {
  contestant
  event
  media
  application
}

enum NotificationType {
  system
  application_update
  event
}

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------

model UserProfile {
  id          String   @id @default(uuid())
  authUserId  String   @unique // Links to Neon Auth User ID
  fullName    String
  phone       String?
  country     String?
  role        Role     @default(contestant)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  application   ContestantApplication?
  formData      ApplicationFormData?
  photos        ContestantPhoto[]
  notifications Notification[]

  @@index([authUserId])
  @@index([role])
}

model ContestantApplication {
  id             String      @id @default(uuid())
  userId         String      @unique
  user           UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio            String      @db.Text
  dateOfBirth    DateTime
  city           String
  country        String
  height         Float
  occupation     String
  educationLevel String
  status         Status      @default(pending)
  isSubmitted    Boolean     @default(false)
  appliedAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model ApplicationFormData {
  id             String      @id @default(uuid())
  userId         String      @unique
  user           UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalInfo   Json
  backgroundInfo Json
  motivation     String      @db.Text
  achievements   Json
  submittedAt    DateTime    @default(now())
  reviewedBy     String?     // Admin authUserId who reviewed this
  reviewedAt     DateTime?
  status         Status      @default(pending)

  @@index([userId])
  @@index([status])
}

model ContestantPhoto {
  id           String      @id @default(uuid())
  contestantId String
  contestant   UserProfile @relation(fields: [contestantId], references: [id], onDelete: Cascade)
  url          String
  publicId     String?
  type         PhotoType
  uploadedAt   DateTime    @default(now())

  @@index([contestantId])
  @@index([type])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  location    String
  eventDate   DateTime
  coverImage  String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([isPublished])
  @@index([eventDate])
}

model MediaGallery {
  id          String        @id @default(uuid())
  title       String
  url         String
  type        MediaType
  category    MediaCategory
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@index([isPublished])
  @@index([category])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String           @db.Text
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id              String     @id @default(uuid())
  adminAuthUserId String
  actionType      ActionType
  targetType      TargetType
  targetId        String
  metadata        Json?
  createdAt       DateTime   @default(now())

  @@index([adminAuthUserId])
  @@index([targetId])
}
